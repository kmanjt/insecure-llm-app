# Site-wide HTTP Basic Auth gate (everything except /health)
BASIC_AUTH_USERNAME=demo
BASIC_AUTH_PASSWORD=change-me

# Upload cap (bytes). Default 10 MiB.
MAX_UPLOAD_BYTES=10485760

# Central blob storage for user uploads (managed-identity auth in prod)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=documents

# Azure AI Search (key-auth for now, wired as a Foundry connection too)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=documents
AZURE_SEARCH_KEY=

# Azure AI Foundry project + agent model
# Connection string format: <region>.api.azureml.ms;<sub-id>;<rg>;<project>
AZURE_AI_PROJECT_CONNECTION_STRING=
AZURE_AI_AGENT_MODEL=gpt-4o-mini

# Local-dev only: set if logging in via az login fails (force a specific UAMI)
# AZURE_CLIENT_ID=
